public int subarraysDivByK(int[] nums, int k) {
    int n = nums.length;
    int sum = 0;
    int res = 0;
    int rem = 0;
    Map<Integer, Integer> f = new HashMap<>();
    f.put(0, 1);
    for (int i = 0; i < n; i++) {
        sum += nums[i];
        rem = sum % k;
        if (rem < 0) {
            rem += k;
        }
        if (f.containsKey(rem)) {
            res += f.get(rem);
        }        
        f.put(rem, f.getOrDefault(rem, 0) + 1);
    }
    return res;
}
