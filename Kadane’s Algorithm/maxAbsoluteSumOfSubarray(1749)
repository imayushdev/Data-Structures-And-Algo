class Solution {
    public int maxAbsoluteSum(int[] nums) {
        int BestMaxSum = nums[0];
        int BestMinSum=nums[0];
        int result =nums[0];
        for(int i =1;i<nums.length;i++){
            int v1 = nums[i];
            int v2 = nums[i]+BestMaxSum;
            int v3 = nums[i]+BestMinSum;
            BestMaxSum=Math.max(v1,Math.max(v2,v3));
            BestMinSum=Math.min(v1,Math.min(v2,v3));
           // BestMaxSum = Math.abs(BestMaxSum);
            // BestMinSum = Math.abs(BestMinSum);
       result = Math.max(result, Math.max(Math.abs(BestMaxSum), Math.abs(BestMinSum)));
           
        }
       
   return Math.abs(result);
    }
}
