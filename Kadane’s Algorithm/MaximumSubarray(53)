class Solution {
    public int maxSubArray(int[] nums) {
        int bestEnding = nums[0];
        int ans = nums[0];
        for(int i = 1 ; i<nums.length;i++){
            int valOne=bestEnding+nums[i];
            int valTwo=nums[i];
            bestEnding=Math.max(valOne,valTwo);
            ans = Math.max(bestEnding,ans);

        }
        return ans;
        
    }
}
